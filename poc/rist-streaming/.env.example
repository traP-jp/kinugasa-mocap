LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecretdevsecretdevsecretdevsecret
LIVEKIT_WS_URL=ws://livekit:7880

ROOM_NAME=rist-poc
VIEWER_IDENTITY=viewer
INGRESS_IDENTITY=rist-bridge
VIEWER_PORT=3000

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=recordings
RECORD_DIR=/recordings
UPLOAD_SHUTDOWN_GRACE=30

RIST_UDP_PORT=9000
RIST_LISTEN_URL=rist://@0.0.0.0:9000
RIST_PUSH_URL=rist://rist-server:9000
RIST_VIDEO_CODEC=libx264
RIST_H264_PROFILE=baseline
RIST_H264_LEVEL=3.1
RIST_VIDEO_BITRATE=3000k
RIST_GOP_SIZE=60

# Fill this after creating an RTMP ingress:
#   ./scripts/create-ingress.sh
LIVEKIT_RTMP_URL=rtmp://ingress:1935/live/REPLACE_WITH_STREAM_KEY

SEGMENT_TIME=10
CAMERA_DEVICE=/dev/video0
CAMERA_SIZE=1280x720
CAMERA_FPS=30
